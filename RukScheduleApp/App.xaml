<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RukScheduleApp"
             xmlns:conv="clr-namespace:RukScheduleApp.Converters"
             x:Class="RukScheduleApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmptyConverter" />
            <conv:IsNotNullConverter x:Key="IsNotNullConverter" />
            <conv:RoleToColorConverter x:Key="RoleColorConverter" />
            <conv:RoleToMessageTextColorConverter x:Key="RoleMessageTextColorConverter" />
            <conv:RoleToSenderLabelConverter x:Key="RoleSenderLabelConverter" />
            <conv:RoleToTextAlignmentConverter x:Key="RoleSenderTextAlignConverter" />
            <conv:RoleToLayoutOptionsConverter x:Key="RoleAlignConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
