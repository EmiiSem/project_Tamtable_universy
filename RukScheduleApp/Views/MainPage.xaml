<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RukScheduleApp.Views.SchedulePage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             Title="Программа просмотра расписания"
             BackgroundColor="{AppThemeBinding Light=#F0F2F7, Dark=#1A1A1E}">

    <!-- Сверху параметры парсинга; под ними — заголовок чата и лента сообщений; внизу ввод. -->
    <Grid Padding="{OnIdiom Phone='12,10,12,8', Default='20,16,20,14'}"
          RowDefinitions="Auto,Auto,*,Auto"
          RowSpacing="10">

        <!-- Параметры парсинга: свёрнуто — одна строка; развёрнуто — форма в ScrollView -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <!-- Свёрнуто -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2E}"
                    Padding="12,10"
                    IsVisible="{Binding ScheduleParametersCollapsed}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="▼ Параметры загрузки расписания"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                    <Label Text="{Binding ScheduleParametersSummary}"
                           FontSize="13"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           TextColor="{AppThemeBinding Light=#111827, Dark=#E5E7EB}" />
                    <Button Text="Развернуть"
                            Command="{Binding ToggleScheduleParametersCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            CornerRadius="10"
                            Padding="10,8"
                            FontSize="13" />
                </VerticalStackLayout>
            </Border>

            <!-- Развёрнуто -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2E}"
                    Padding="0"
                    IsVisible="{Binding ScheduleParametersExpanded}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,*" MaximumHeightRequest="380">
                    <Button Grid.Row="0"
                            Text="▲ Свернуть параметры"
                            Command="{Binding ToggleScheduleParametersCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="13"
                            HorizontalOptions="End"
                            Padding="12,8" />
                    <ScrollView Grid.Row="1" Padding="12,0,12,12">
                        <VerticalStackLayout Spacing="12">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Филиал"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                <Picker ItemsSource="{Binding Branches}"
                                        SelectedItem="{Binding SelectedBranch}"
                                        Title="Выберите филиал" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Сотрудник"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                <Label Text="Сначала выберите филиал — список сотрудников появится ниже."
                                       FontSize="12"
                                       IsVisible="{Binding ShowTeacherBranchHint}"
                                       TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                                       LineBreakMode="WordWrap" />
                                <HorizontalStackLayout Spacing="10"
                                                       IsVisible="{Binding ShowTeacherLoadingRow}"
                                                       VerticalOptions="Center">
                                    <ActivityIndicator IsRunning="True"
                                                       WidthRequest="24"
                                                       HeightRequest="24"
                                                       Color="{StaticResource Primary}" />
                                    <Label Text="Загрузка списка сотрудников…"
                                           FontSize="13"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                </HorizontalStackLayout>
                                <SearchBar Text="{Binding TeacherSearchText, Mode=TwoWay}"
                                           Placeholder="Поиск по ФИО..."
                                           IsEnabled="{Binding Teachers, Converter={StaticResource IsNotNullConverter}}" />
                                <Label Text="Ничего не найдено. Измените запрос."
                                       FontSize="12"
                                       IsVisible="{Binding ShowTeacherEmptySearchMessage}"
                                       TextColor="{AppThemeBinding Light=#B45309, Dark=#FBBF24}"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding SelectedTeacher, StringFormat='Выбрано: {0}'}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       IsVisible="{Binding SelectedTeacher, Converter={StaticResource StringIsNotNullOrEmptyConverter}}"
                                       TextColor="{StaticResource Primary}" />
                                <CollectionView ItemsSource="{Binding FilteredTeachers}"
                                                MaximumHeightRequest="140"
                                                SelectionMode="None"
                                                IsVisible="{Binding Teachers, Converter={StaticResource IsNotNullConverter}}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6"
                                                    Padding="10,8"
                                                    BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#3A3A3C}"
                                                    StrokeThickness="0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <Grid>
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectTeacherCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Grid.GestureRecognizers>
                                                    <Label Text="{Binding .}"
                                                           LineBreakMode="TailTruncation"
                                                           FontSize="14"
                                                           TextColor="{AppThemeBinding Light=#111827, Dark=#F3F4F6}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Дата"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                <DatePicker Date="{Binding SelectedDate}" />
                                <Button Text="Загрузить расписание"
                                        Command="{Binding LoadScheduleCommand}"
                                        IsEnabled="{Binding SelectedTeacher, Converter={StaticResource StringIsNotNullOrEmptyConverter}}"
                                        HorizontalOptions="Fill"
                                        CornerRadius="12"
                                        Padding="14,12" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Заголовок зоны чата (строка 1) и кнопки (строка 2) — без наложения -->
        <VerticalStackLayout Grid.Row="1"
                             Spacing="8"
                             Margin="0,4,0,0">
            <HorizontalStackLayout HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   WidthRequest="24"
                                   HeightRequest="24"
                                   VerticalOptions="Center"
                                   Color="{StaticResource Primary}" />
                <Label Text="AI Помощник"
                       VerticalOptions="Center"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#111827, Dark=#F5F5F7}" />
            </HorizontalStackLayout>
            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="8">
                <Button Text="Очистить"
                        Command="{Binding ClearChatCommand}"
                        CornerRadius="8"
                        BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3C}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}">
                    <Button.FontSize>
                        <OnIdiom x:TypeArguments="x:Double" Phone="11" Default="12" />
                    </Button.FontSize>
                    <Button.Padding>
                        <OnIdiom x:TypeArguments="Thickness">
                            <OnIdiom.Phone>
                                <Thickness>8,4</Thickness>
                            </OnIdiom.Phone>
                            <OnIdiom.Default>
                                <Thickness>10,6</Thickness>
                            </OnIdiom.Default>
                        </OnIdiom>
                    </Button.Padding>
                    <Button.MinimumHeightRequest>
                        <OnIdiom x:TypeArguments="x:Double" Phone="32" Default="40" />
                    </Button.MinimumHeightRequest>
                </Button>
                <Button Text="Копировать всё"
                        Command="{Binding CopyAllChatCommand}"
                        CornerRadius="8"
                        BackgroundColor="{AppThemeBinding Light=#E5E7EB, Dark=#3A3A3C}"
                        TextColor="{AppThemeBinding Light=#111827, Dark=#F9FAFB}">
                    <Button.FontSize>
                        <OnIdiom x:TypeArguments="x:Double" Phone="11" Default="12" />
                    </Button.FontSize>
                    <Button.Padding>
                        <OnIdiom x:TypeArguments="Thickness">
                            <OnIdiom.Phone>
                                <Thickness>8,4</Thickness>
                            </OnIdiom.Phone>
                            <OnIdiom.Default>
                                <Thickness>10,6</Thickness>
                            </OnIdiom.Default>
                        </OnIdiom>
                    </Button.Padding>
                    <Button.MinimumHeightRequest>
                        <OnIdiom x:TypeArguments="x:Double" Phone="32" Default="40" />
                    </Button.MinimumHeightRequest>
                </Button>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Диалог: основная область экрана -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding ChatHistory}"
                        SelectionMode="None"
                        VerticalOptions="Fill"
                        HorizontalOptions="Fill"
                        BackgroundColor="Transparent"
                        ItemSizingStrategy="MeasureAllItems">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="0,0,0,16"
                                         Spacing="6"
                                         HorizontalOptions="{Binding Role, Converter={StaticResource RoleAlignConverter}}">
                        <Label Text="{Binding Role, Converter={StaticResource RoleSenderLabelConverter}}"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B7280, Dark=#8E8E93}"
                               HorizontalOptions="{Binding Role, Converter={StaticResource RoleAlignConverter}}"
                               HorizontalTextAlignment="{Binding Role, Converter={StaticResource RoleSenderTextAlignConverter}}" />
                        <Border MaximumWidthRequest="340"
                                HorizontalOptions="{Binding Role, Converter={StaticResource RoleAlignConverter}}"
                                StrokeThickness="0"
                                Padding="12,10"
                                BackgroundColor="{Binding Role, Converter={StaticResource RoleColorConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding Content}"
                                       TextColor="{Binding Role, Converter={StaticResource RoleMessageTextColorConverter}}"
                                       LineBreakMode="WordWrap" />
                                <Button Grid.Column="1"
                                        Text="Копировать"
                                        FontSize="11"
                                        Padding="8,4"
                                        CornerRadius="8"
                                        VerticalOptions="Start"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#3A3A3C}"
                                        TextColor="{AppThemeBinding Light=#374151, Dark=#E5E7EB}"
                                        Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.CopyMessageCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Ввод: поле + широкая кнопка снизу (референс) -->
        <VerticalStackLayout Grid.Row="3"
                             Spacing="10"
                             Padding="0,4,0,0">
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D1D5DB, Dark=#3A3A3C}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2C2C2E}"
                    Padding="12,4">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Entry Text="{Binding UserInput}"
                       Placeholder="Введите ваше сообщение здесь..."
                       ReturnType="Send"
                       ReturnCommand="{Binding SendChatMessageCommand}" />
            </Border>
            <Button Text="Отправить сообщение"
                    Command="{Binding SendChatMessageCommand}"
                    HorizontalOptions="Fill"
                    CornerRadius="12"
                    Padding="16,14"
                    FontSize="15" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
